# ── MongoDB Connection ────────────────────────────────────────
# Local MongoDB (default)
MONGO_URI=mongodb://127.0.0.1:27017/shiftapp

# MongoDB Atlas (cloud) - uncomment and replace with your Atlas URI
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shiftapp?retryWrites=true&w=majority

# ── JWT Secret ────────────────────────────────────────────────
JWT_SECRET=shiftapp_super_secret_key_change_in_production_2024

# ── Server Port ───────────────────────────────────────────────
PORT=5000

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development
